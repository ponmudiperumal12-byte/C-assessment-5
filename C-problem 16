#include <stdio.h>
int main()
{
    int a, temp, last, power = 1, result;
    printf ("enter the number:");
    scanf("%d", &a);

    temp = a;

    for(temp ; temp >= 10; temp = temp / 10)
    {
        power = power * 10;
    }

    last = temp;

    if(last % 2 == 0)
        printf("%d",a);
    else
    {
        result = a - power;
        printf("%d", result);
    }
}
