#include <stdio.h>
int main()
{
    int n, i, count = 0;
    int temp, sum = 0;
    printf (" enter the number:");
    scanf("%d", &n);
    for(i = 2; i < n; i++)
    {
        if(n % i == 0)
        {
            count++;
        }
    }
    temp = n;
    for(temp ; temp > 0; temp = temp / 10)
    {
        sum = sum + (temp % 10);
    }
    if(count == 0 && n > 1 && sum == 14)
        printf("equal to 14");
    else
        printf("No");
}
