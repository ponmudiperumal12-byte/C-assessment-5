#include <stdio.h>
int main()
{
    int count = 0, i, j, factor;
    for(i = 2; i <= 9; i++)
    {
        factor = 0;
        for(j = 2; j < i; j++)
        {
            if(i % j == 0)
            {
                factor++;
            }
        }
        if(factor == 0)
        {
            count++;
        }
    }
    printf("%d", count);
}
