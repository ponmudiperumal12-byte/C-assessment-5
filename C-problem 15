#include <stdio.h>
int main()
{
    int num, temp, first, last;
    int power = 1, middle, result;
    printf("enter the number:");
    scanf("%d", &num);
    last = num % 10;
    for(temp = num; temp >= 10; temp = temp / 10)
    {
        power = power * 10;
    }
    first = temp;
    middle = (num % power) / 10;
    result = last * power + middle * 10 + first;
    printf("%d", result);
}
