#include <stdio.h>
int main()
{
    int n, i, count = 0;
    printf ("enter the number:");
    scanf("%d", &n);

    for(i = 2; i < n; i++)
    {
        if(n % i == 0)
        {
            count++;
        }
    }

    if(n > 1 && count == 0)
        printf("Prime");
    else
        printf("Not Prime");
}
