#include <stdio.h>
int main()
{
    int i, a, sum, count = 0;
    for(i = 1; i < 100000; i++)
    {
        sum = 0;
        a = i;

        for(a ;a > 0; a = a / 10)
        {
            sum = sum + (a % 10);
        }

        if(sum == 14)
        {
            count++;
        }
    }
    printf("%d", count);
}
