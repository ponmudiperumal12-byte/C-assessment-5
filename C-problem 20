#include <stdio.h>
int main()
{
    int n, m, i, count = 0;
    printf("enter the number:");
    scanf("%d", &n);
    m = (n / 10) % 100;
    for(i = 2; i < m; i++)
    {
        if(m % i == 0)
        {
            count++;
        }
    }
    if(m > 1 && count == 0)
        printf("Prime");
    else
        printf("Not Prime");
}
